DSTACK_DOCKER_REGISTRY=ghcr.io # github registry.
DSTACK_DOCKER_USERNAME= # GitHub username with read access to the package.
DSTACK_DOCKER_PASSWORD= # Classic GitHub PAT with the read:packages scope.
OUTLAYER__SEED= # Signer seed (hex). Temporary until CKD; keep secret.
OUTLAYER__SERVICE__RESOLVER__NEAR_RPC_URL= # Dedicated NEAR mainnet RPC; the public rpc.mainnet.near.org is rate-limited.
OUTLAYER__GRPC_SERVER__CONCURRENCY_LIMIT_PER_CONNECTION=500 # Max concurrent requests per gRPC connection.
OUTLAYER__GRPC__MAX_PARALLEL_WASM_EXECUTIONS=8 # Max WASM executions running in parallel. (given 4vcpu in phala)
